# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paypal_qbo
DB_USER=postgres
DB_PASSWORD=changeme_strong_password

# ──────────────────────────────────────────────
# App Security
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generate ENCRYPTION_KEY with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ──────────────────────────────────────────────
JWT_SECRET=replace_with_64_hex_chars
ENCRYPTION_KEY=replace_with_32_hex_chars

# ──────────────────────────────────────────────
# QuickBooks Online OAuth
# Register your app at https://developer.intuit.com
# ──────────────────────────────────────────────
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3001/api/quickbooks/callback
QBO_ENVIRONMENT=sandbox
# QBO_ENVIRONMENT=production

# ──────────────────────────────────────────────
# PayPal — entered via the Setup Wizard UI
# (stored encrypted in the database)
# These env vars are used only as fallback / dev convenience
# ──────────────────────────────────────────────
PAYPAL_ENVIRONMENT=sandbox
# PAYPAL_ENVIRONMENT=live

# ──────────────────────────────────────────────
# App URLs
# ──────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Default admin user (used only during seed)
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password
